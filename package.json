{
  "name": "pc-ctx",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @pc-ctx/core build",
    "build:cli": "pnpm --filter @pc-ctx/cli build",
    "build:mcp": "pnpm --filter @pc-ctx/mcp build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "format:check": "biome format",
    "knip": "knip --config config/knip.config.ts --no-config-hints",
    "fallow": "fallow",
    "test": "pnpm test:unit && pnpm test:it",
    "test:unit": "vitest run --config config/vitest.unit.config.ts",
    "test:it": "vitest run --config config/vitest.it.config.ts",
    "test:unit:watch": "vitest --config config/vitest.unit.config.ts",
    "test:it:watch": "vitest --config config/vitest.it.config.ts",
    "clean": "pnpm -r clean",
    "depcruise": "depcruise packages --config config/.dependency-cruiser.cjs",
    "depcruise:graph": "depcruise packages --config config/.dependency-cruiser.cjs --output-type dot | dot -T png > graph.png",
    "depcruise:graph:svg": "depcruise packages --config config/.dependency-cruiser.cjs --output-type dot | dot -T svg > graph.svg",
    "check": "pnpm lint && pnpm knip && pnpm build && pnpm typecheck && pnpm depcruise && pnpm test",
    "check:ci": "pnpm lint && pnpm knip && pnpm build && pnpm typecheck && pnpm depcruise && pnpm test:unit",
    "tag": "npm version"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.8.0",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@biomejs/biome": "^1.9.4",
    "@vitest/coverage-v8": "^4.1.9",
    "dependency-cruiser": "^17.4.3",
    "knip": "^6.17.1",
    "vitest": "^4.1.9"
  },
  "version": "0.0.1"
}
