{
  "name": "@pc-ctx/cli",
  "version": "0.2.0",
  "description": "CLI for managing markdown-based plans with YAML frontmatter — list, show, status, validate, sync, and more",
  "type": "module",
  "bin": {
    "ctx": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "echo ok",
    "clean": "rm -rf dist",
    "test": "echo ok",
    "test:unit": "vitest run --config ../../config/vitest.unit.config.ts",
    "test:it": "vitest run --config ../../config/vitest.it.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samir1498/pc-ctx.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/samir1498/pc-ctx/issues"
  },
  "license": "MIT",
  "author": "Samir Bettahar",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@pc-ctx/core": "workspace:^",
    "citty": "^0.2.2",
    "hono": "^4.12.27",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.7.0"
  }
}
