{
  "name": "@pc-ctx/mcp",
  "version": "0.2.2",
  "description": "MCP server exposing pc-ctx plans as AI agent tools — plan_list, plan_show, plan_status, plan_validate",
  "type": "module",
  "bin": {
    "pc-ctx-mcp": "dist/main.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "echo ok",
    "clean": "rm -rf dist",
    "test": "echo ok",
    "test:unit": "vitest run --config ../../config/vitest.unit.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samir1498/pc-ctx.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/samir1498/pc-ctx/issues"
  },
  "license": "MIT",
  "author": "Samir Bettahar",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "@pc-ctx/core": "workspace:^",
    "js-yaml": "^4.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.7.0"
  }
}
